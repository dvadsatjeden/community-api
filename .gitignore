# Secrets — never commit
.env
.env.*
!.env.example

# Claude Code local settings
.claude/

# App compiled output (runs from src via tsx)
app/dist/

# Node
node_modules/
community-web/node_modules/
app/node_modules/

# Build outputs
community-web/dist/
community-web/dist-standalone/
standalone-dist/

# WP plugin built assets (regenerated by npm run build:wp)
wp-content/plugins/dvadsatjeden-community/assets/community-app.js
wp-content/plugins/dvadsatjeden-community/assets/community-app.js.map
wp-content/plugins/dvadsatjeden-community/assets/community-app.css
wp-content/plugins/dvadsatjeden-community/assets/Db.worker-*.js
wp-content/plugins/dvadsatjeden-community/assets/sqlite3-*.js
wp-content/plugins/dvadsatjeden-community/assets/sqlite3-*.wasm
wp-content/plugins/dvadsatjeden-community/assets/index.html

# ZIP releases
*.zip

# Runtime data (Docker volumes)
data/
app/data/

# Vite build stamp (postbuild reads it; not needed in git)
**/.dvc-build-meta.json

# Misc
.DS_Store
*.log
