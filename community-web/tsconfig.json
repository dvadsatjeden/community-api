{
  "compilerOptions": {
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "types": [
      "react",
      "react-dom",
      "vite/client"
    ],
    "skipLibCheck": true
  },
  "include": [
    "src"
  ]
}
