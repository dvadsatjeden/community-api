{
  "name": "@dvadsatjeden/community-web",
  "version": "0.9.8",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build && node ./scripts/postbuild-wasm-alias.mjs",
    "build:wp": "tsc -p tsconfig.json --noEmit && vite build && node ./scripts/postbuild-wasm-alias.mjs",
    "build:standalone": "tsc -p tsconfig.json --noEmit && vite build --config vite.config.standalone.ts && node ./scripts/postbuild-wasm-alias.mjs standalone",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@evolu/common": "^7.4.1",
    "@evolu/react": "^10.4.0",
    "@evolu/react-web": "^2.4.0",
    "@noble/hashes": "^1.7.0",
    "@scure/bip39": "^1.6.0",
    "@types/leaflet": "^1.9.21",
    "leaflet": "^1.9.4",
    "nostr-tools": "^2.23.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.5"
  }
}
