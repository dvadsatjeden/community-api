PORT=3021
# Optional: URL returned by GET /v1/config as apiBaseUrl (forks / staging). Falls back to https://api.dvadsatjeden.org
PUBLIC_API_BASE_URL=
EVENTS_SOURCE_URL=https://prevadzky.dvadsatjeden.org/wp-json/dvadsatjeden-events/v1/list?country=sk
RSVP_PERSIST_PATH=/app/data/rsvp-votes.json
IMPORT_STATUS_PATH=/app/data/import-status.json
GEOCODE_CACHE_PATH=/app/data/geocode-cache.json
IMPORT_INTERVAL_MINUTES=30
CORS_ORIGIN=https://www.dvadsatjeden.org,https://app.dvadsatjeden.org,http://localhost:4173
IMPORT_SECRET=change-me-in-production
# Optional: enables GET/POST /v1/auth/nostr/* and features.nostrLogin in GET /v1/config (long random secret).
NOSTR_AUTH_SECRET=
# Optional: Redis URL for shared Nostr auth challenges (multi-instance). If unset, challenges stay in-memory per process.
REDIS_URL=
NODE_ENV=production
VAPID_PUBLIC_KEY=generate-with-web-push
VAPID_PRIVATE_KEY=generate-with-web-push
VAPID_SUBJECT=mailto:admin@example.com
